{
  "name": "evozen",
  "version": "0.8.1",
  "description": "EvoZen",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@evozen/web",
    "build": "npm run build --workspace=@evozen/web",
    "test": "npm run test --workspace=@evozen/game-core",
    "typecheck": "npm run typecheck --workspace=@evozen/game-core",
    "check": "npm run typecheck && npm run test --workspace=@evozen/game-core -- --coverage && node scripts/audit.mjs",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "keywords": [
    "EvoZen"
  ],
  "license": "MPL-2.0"
}
