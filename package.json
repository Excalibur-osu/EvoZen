{
  "name": "evozen",
  "version": "0.7.0",
  "description": "EvoZen — 进化之禅",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@evozen/web",
    "build": "npm run build --workspace=@evozen/web",
    "test": "npm run test --workspace=@evozen/game-core",
    "test:coverage": "npm run test:coverage --workspace=@evozen/game-core",
    "typecheck": "npm run typecheck --workspace=@evozen/game-core",
    "check": "npm run typecheck && npm test && npm run audit:parity",
    "audit:parity": "node scripts/audit.mjs",
    "legacy:serve": "cd legacy && npx servehere -c"
  },
  "keywords": [
    "EvoZen"
  ],
  "license": "MPL-2.0"
}
